@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Public interface dependencies (OpenCV headers/libs and Eigen are exposed
# through the installed headers and the exported link interface).
find_dependency(OpenCV COMPONENTS core imgproc calib3d imgcodecs)
find_dependency(Eigen3)

# When built with CUDA the (static) library propagates a private link to
# CUDA::cudart through its export, so consumers must be able to resolve it.
if(@CCD_WITH_CUDA@)
  find_dependency(CUDAToolkit)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/camera_chessboard_detectorTargets.cmake")

check_required_components(camera_chessboard_detector)
